{
  "name": "fas-operations",
  "version": "0.1.0",
  "description": "FAS - 24/7 AI Worker System",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/gateway/server.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "captain": "tsx src/captain/main.ts",
    "gateway": "tsx src/gateway/server.ts",
    "watcher": "tsx src/watchdog/output_watcher.ts",
    "hunter": "tsx src/hunter/main.ts",
    "mode:sleep": "bash scripts/mode_switch.sh sleep",
    "mode:awake": "bash scripts/mode_switch.sh awake",
    "academy:text": "tsx src/academy/cli_parent_message.ts",
    "academy:test": "tsx src/academy/cli_test_generator.ts",
    "academy:student": "tsx src/academy/cli_student.ts"
  },
  "keywords": [
    "automation",
    "ai-agents"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@notionhq/client": "^5.13.0",
    "@slack/web-api": "^7.15.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "pdfkit": "^0.18.0",
    "playwright": "^1.52.0",
    "uuid": "^13.0.0",
    "yaml": "^2.8.2"
  }
}
